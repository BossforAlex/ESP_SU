# ESP32-C3 Super Mini USB Fastboot Tool
# 自定义配置覆盖（CI 和本地构建共用）
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_TINYUSB_ENABLED=y
CONFIG_TINYUSB_TASK_PRIORITY=5
CONFIG_TINYUSB_DESC_USE_ESPRESSIF_VID=y
CONFIG_TINYUSB_DESC_CUSTOM_PID=0x4003
CONFIG_TINYUSB_DESC_MANUFACTURER_STRING="ESP32C3"
CONFIG_TINYUSB_DESC_PRODUCT_STRING="USB Fastboot Tool"
CONFIG_TINYUSB_DESC_SERIAL_STRING="123456"
CONFIG_TINYUSB_HID_KEYBOARD=y
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_UNICORE=y
CONFIG_ESP_MAIN_TASK_STACK_SIZE=4096